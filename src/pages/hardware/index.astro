---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import Card from '../../components/ui/Card.astro';
import CTASection from '../../components/ui/CTASection.astro';

const hardware = (await getCollection('hardware')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="سخت‌افزار"
  description="کارت‌خوان‌های NFC و RFID نوپردازان؛ زیرساخت سخت‌افزاری راهکارهای باشگاه مشتریان و مدیریت تگ NFC."
  breadcrumb={[
    { name: 'خانه', url: '/' },
    { name: 'سخت‌افزار', url: '/hardware/' },
  ]}
>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[{ name: 'خانه', href: '/' }, { name: 'سخت‌افزار', href: '/hardware/' }]} />
    <h1 class="text-3xl font-extrabold">سخت‌افزار</h1>
    <p class="mt-4 max-w-2xl leading-8 text-[var(--color-text-muted)]">
      این دستگاه‌ها زیرساخت راهکارهای نرم‌افزاری نوپردازان هستند و به‌صورت مستقل هم قابل خریداری‌اند.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {hardware.map((h) => (
        <Card href={`/hardware/${h.id}/`} title={h.data.title} summary={h.data.summary} icon={h.data.icon} stat={h.data.customers} />
      ))}
    </div>
  </div>

  <CTASection />
</BaseLayout>
