---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/ui/Card.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import CTASection from '../components/ui/CTASection.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { withBase } from '../lib/url';

const solutions = (await getCollection('solutions')).sort((a, b) => a.data.order - b.data.order);
const hardware = (await getCollection('hardware')).sort((a, b) => a.data.order - b.data.order);
const portfolio = (await getCollection('portfolio')).sort((a, b) => a.data.order - b.data.order);
const featuredTestimonials = (await getCollection('testimonials'))
  .filter((t) => t.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="خانه"
  description="نوپردازان زندگی هوشمند؛ شرکت مهندسی نرم‌افزار، طراح راهکارهای باشگاه مشتریان، فروشگاه‌ساز اینترنتی، یکپارچه‌سازی حسابداری و مدیریت تگ NFC."
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <h1 class="text-3xl font-extrabold leading-tight sm:text-4xl lg:text-5xl">
          راهکارهای نرم‌افزاری که <span class="text-[var(--color-primary)]">کسب‌وکار شما</span> را می‌شناسند
        </h1>
        <p class="mt-6 text-lg leading-8 text-[var(--color-text-muted)]">
          از باشگاه مشتریان و فروشگاه‌ساز اینترنتی تا یکپارچه‌سازی حسابداری سپیدار — راهکارهای آماده‌ای که همین حالا
          توسط ده‌ها کسب‌وکار ایرانی در حال استفاده هستند، نه ایده یا نمونه.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/solutions/" variant="primary">مشاهده راهکارها</Button>
          <Button href="/contact/" variant="secondary">تماس با ما</Button>
        </div>
      </div>
      <div class="isometric-hero" aria-hidden="true">
        <svg
          viewBox="0 0 480 420"
          style="overflow: visible;"
          class="mx-auto w-full max-w-lg"
          role="img"
          aria-label="نمایش مداری محصولات نوپردازان: کارت وفاداری، تگ RFID، نرم‌افزار بدنسازی و فروشگاه اینترنتی در حال گردش دور نشان مرکزی"
        >
          <g transform="translate(240,206)">
            <!-- faint orbit ring -->
            <ellipse cx="0" cy="0" rx="196" ry="100" fill="none" stroke="var(--color-border)" stroke-dasharray="3 7" opacity="0.6"></ellipse>

            <!-- orbiting tiles: static position on the ellipse, counter-rotated so each tile stays upright -->
            <g class="orbit-group">
              <!-- top: accounting sync -->
              <g transform="translate(0,-100)">
                <g class="orbit-counter glow-primary">
                  <g class="pop-in" style="animation-delay: .15s">
                    <rect x="-30" y="-22" width="60" height="44" rx="9" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"></rect>
                    <path d="M-10 -6 -3 -6a8 8 0 0 1 0 16l-9 0M10 6 3 6a8 8 0 0 1 0-16l9 0" stroke="var(--color-primary)" stroke-width="2.3" stroke-linecap="round" fill="none"></path>
                  </g>
                </g>
              </g>

              <!-- upper-right: RFID / NFC tag -->
              <g transform="translate(186,-31)">
                <g class="orbit-counter glow-accent">
                  <g class="pop-in" style="animation-delay: .3s" transform="rotate(10)">
                    <rect x="-34" y="-30" width="68" height="60" rx="12" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"></rect>
                    <circle cx="0" cy="4" r="9" fill="none" stroke="var(--color-accent)" stroke-width="2.5"></circle>
                    <path d="M13 -6a13 13 0 0 1 0 20M20 -13a22 22 0 0 1 0 34" stroke="var(--color-accent)" stroke-width="2.2" stroke-linecap="round" fill="none"></path>
                    <circle cx="-15" cy="-15" r="3" fill="var(--color-accent)"></circle>
                  </g>
                </g>
              </g>

              <!-- lower-right: online store -->
              <g transform="translate(115,81)">
                <g class="orbit-counter glow-accent">
                  <g class="pop-in" style="animation-delay: .45s" transform="rotate(9)">
                    <rect x="-38" y="-30" width="76" height="58" rx="9" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"></rect>
                    <path d="M-13 -8V-11a13 13 0 0 1 26 0v3M-19 -8h38l-3 24a4 4 0 0 1-4 3.5H-12a4 4 0 0 1-4-3.5l-3-24Z" fill="none" stroke="var(--color-accent)" stroke-width="2.2" stroke-linejoin="round"></path>
                  </g>
                </g>
              </g>

              <!-- lower-left: dumbbell / fitness software -->
              <g transform="translate(-115,81)">
                <g class="orbit-counter glow-primary">
                  <g class="pop-in" style="animation-delay: .6s" transform="rotate(-8)">
                    <rect x="-40" y="-28" width="80" height="56" rx="9" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"></rect>
                    <g stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round" fill="none">
                      <path d="M-19 0h38"></path>
                      <path d="M-26 -8v16M-32 -5v10M26 -8v16M32 -5v10"></path>
                    </g>
                  </g>
                </g>
              </g>

              <!-- upper-left: loyalty card -->
              <g transform="translate(-186,-31)">
                <g class="orbit-counter glow-primary">
                  <g class="pop-in" style="animation-delay: .75s" transform="rotate(-10)">
                    <rect x="-42" y="-28" width="84" height="56" rx="9" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"></rect>
                    <rect x="-30" y="-14" width="18" height="13" rx="3" fill="var(--color-warning)" opacity="0.85"></rect>
                    <path d="M-30 12h40M-30 20h24" stroke="var(--color-text-muted)" stroke-width="2.5" stroke-linecap="round"></path>
                    <path d="M18 -16a10 10 0 0 1 0 14M25 -21a17 17 0 0 1 0 24" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" fill="none"></path>
                  </g>
                </g>
              </g>
            </g>

            <!-- central hub: placeholder mark, swap for the real logo once received -->
            <g class="hub-pulse glow-primary">
              <circle cx="0" cy="0" r="46" fill="var(--color-primary)" opacity="0.1"></circle>
              <circle cx="0" cy="0" r="34" fill="var(--color-surface)" stroke="var(--color-primary)" stroke-width="2.5"></circle>
              <text x="0" y="2" text-anchor="middle" dominant-baseline="central" font-size="30" font-weight="800" fill="var(--color-primary)" style="font-family: var(--font-sans)">ن</text>
            </g>
          </g>
        </svg>
      </div>
    </div>

    <div id="home-stats" class="mt-14 grid grid-cols-2 gap-6 border-t border-[var(--color-border)] pt-8 sm:grid-cols-4">
      <div class="text-center">
        <p class="stat-counter text-2xl font-extrabold text-[var(--color-primary)]" data-target="7" data-suffix="">۰</p>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">راهکار و محصول آماده</p>
      </div>
      <div class="text-center">
        <p class="stat-counter text-2xl font-extrabold text-[var(--color-primary)]" data-target="50" data-suffix="+">۰</p>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">مشتری فعال برای هر راهکار</p>
      </div>
      <div class="text-center">
        <p class="stat-counter text-2xl font-extrabold text-[var(--color-primary)]" data-target="100" data-suffix="+">۰</p>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">مربی و باشگاه با شهروز فیتنس</p>
      </div>
      <div class="text-center">
        <p class="stat-counter text-2xl font-extrabold text-[var(--color-primary)]" data-target="6" data-suffix=" ماه">۰</p>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">پشتیبانی رایگان روی هر راهکار</p>
      </div>
    </div>

    <script is:inline>
      (() => {
        const persianDigits = ['۰', '۱', '۲', '۳', '۴', '۵', '۶', '۷', '۸', '۹'];
        const toPersianDigits = (n) =>
          String(n)
            .split('')
            .map((ch) => (ch >= '0' && ch <= '9' ? persianDigits[+ch] : ch))
            .join('');

        const els = document.querySelectorAll('#home-stats .stat-counter');
        if (!els.length) return;

        const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

        const animate = (el) => {
          const target = parseInt(el.dataset.target, 10);
          const suffix = el.dataset.suffix || '';
          if (reduceMotion) {
            el.textContent = toPersianDigits(target) + suffix;
            return;
          }
          const duration = 1100;
          const start = performance.now();
          const tick = (now) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const value = Math.round(target * eased);
            el.textContent = toPersianDigits(value) + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                animate(entry.target);
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.4 }
        );

        els.forEach((el) => observer.observe(el));
      })();
    </script>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold">راهکارها</h2>
      <a href={withBase("/solutions/")} class="text-sm font-medium text-[var(--color-primary)]">مشاهده همه</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {solutions.map((s) => (
        <Card href={`/solutions/${s.id}/`} title={s.data.title} summary={s.data.summary} icon={s.data.icon} stat={s.data.customers} />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold">سخت‌افزار</h2>
      <a href={withBase("/hardware/")} class="text-sm font-medium text-[var(--color-primary)]">مشاهده همه</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      {hardware.map((h) => (
        <Card href={`/hardware/${h.id}/`} title={h.data.title} summary={h.data.summary} icon={h.data.icon} stat={h.data.customers} />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <div class="mb-8 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold">نظر مشتریان درباره‌ی ما</h2>
      <a href={withBase("/testimonials/")} class="text-sm font-medium text-[var(--color-primary)]">مشاهده همه</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-3">
      {featuredTestimonials.map((t) => (
        <TestimonialCard quote={t.data.quote} author={t.data.author} company={t.data.company} companyUrl={t.data.companyUrl} />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <div class="grid items-center gap-8 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8 sm:p-10 lg:grid-cols-2">
      <div>
        <div class="flex items-center gap-3">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
            <Icon name={portfolio[0]?.data.icon ?? 'dumbbell'} class="h-5.5 w-5.5" />
          </span>
          {portfolio[0]?.data.customers && (
            <span class="rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-2.5 py-1 text-xs font-medium text-[var(--color-accent)]">
              {portfolio[0].data.customers}
            </span>
          )}
        </div>
        <h2 class="mt-4 text-2xl font-bold">{portfolio[0]?.data.title}</h2>
        <p class="mt-3 leading-8 text-[var(--color-text-muted)]">{portfolio[0]?.data.summary}</p>
        <Button href={`/portfolio/${portfolio[0]?.id}/`} variant="ghost" class="mt-4 px-0">
          مشاهده کامل محصول ←
        </Button>
      </div>
      <div>
        <p class="leading-8 text-[var(--color-text-muted)]">
          علاوه‌بر محصولات آماده، تیم نوپردازان توانایی توسعه‌ی نرم‌افزار اختصاصی متناسب با نیاز کسب‌وکار شما را هم دارد.
          <a href={withBase("/about/")} class="font-medium text-[var(--color-primary)]">بیشتر درباره‌ی ما بدانید ←</a>
        </p>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  /* orbit-group sweeps all five tiles around the hub; orbit-counter spins
     each tile the exact opposite amount so it stays visually upright while
     its position travels around the ellipse — like a planet that doesn't
     tumble as it revolves. */
  .orbit-group {
    animation: orbit 34s linear infinite;
    transform-origin: 0px 0px;
  }
  .orbit-counter {
    animation: orbit-counter 34s linear infinite;
    transform-origin: 0px 0px;
  }
  @keyframes orbit {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes orbit-counter {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(-360deg);
    }
  }

  .hub-pulse {
    animation: hub-pulse 3.2s ease-in-out infinite;
    transform-origin: 0px 0px;
  }
  @keyframes hub-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  .pop-in {
    animation: pop-in 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
    transform-origin: center;
  }
  @keyframes pop-in {
    from {
      opacity: 0;
      transform: scale(0.6);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* neon-tinted glow using the same brand tokens as the rest of the site,
     not a generic gray drop-shadow */
  .glow-primary {
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--color-primary) 45%, transparent));
  }
  .glow-accent {
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--color-accent) 45%, transparent));
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit-group,
    .orbit-counter,
    .hub-pulse,
    .pop-in {
      animation: none;
    }
  }
</style>
