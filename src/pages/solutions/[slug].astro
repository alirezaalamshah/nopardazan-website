---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CTASection from '../../components/ui/CTASection.astro';
import Card from '../../components/ui/Card.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';

export async function getStaticPaths() {
  const solutions = await getCollection('solutions');
  return solutions.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const relatedHardwareEntries = await Promise.all(
  (entry.data.relatedHardware ?? []).map((slug: string) => getEntry('hardware', slug))
);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.seoDescription}
  breadcrumb={[
    { name: 'خانه', url: '/' },
    { name: 'راهکارها', url: '/solutions/' },
    { name: entry.data.title, url: `/solutions/${entry.id}/` },
  ]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumb
      items={[
        { name: 'خانه', href: '/' },
        { name: 'راهکارها', href: '/solutions/' },
        { name: entry.data.title, href: `/solutions/${entry.id}/` },
      ]}
    />

    <div class="grid gap-10 lg:grid-cols-[1fr_320px] lg:items-start">
      <article class="min-w-0">
        <div class="flex flex-wrap items-center gap-3">
          <span class="inline-flex h-12 w-12 flex-none items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)] shadow-[var(--shadow-glow-primary)]">
            <Icon name={entry.data.icon} class="h-6 w-6" />
          </span>
          <span class="rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-1 text-sm font-medium text-[var(--color-accent)]">
            {entry.data.customers} همین حالا از این راهکار استفاده می‌کنند
          </span>
        </div>
        <h1 class="mt-4 text-3xl font-extrabold">{entry.data.title}</h1>
        <p class="mt-4 text-lg leading-8 text-[var(--color-text-muted)]">{entry.data.summary}</p>

        {
          entry.data.features?.length > 0 && (
            <ul class="mt-8 grid gap-3 sm:grid-cols-2">
              {entry.data.features.map((f: string) => (
                <li class="flex items-start gap-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm">
                  <span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-[var(--color-accent)]/15 text-[var(--color-accent)]">
                    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  {f}
                </li>
              ))}
            </ul>
          )
        }

        <div class="prose-content mt-10 max-w-none leading-8">
          <Content />
        </div>
      </article>

      <aside class="lg:sticky lg:top-24">
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)]">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
            <Icon name={entry.data.icon} class="h-5.5 w-5.5" />
          </span>
          <p class="mt-4 text-2xl font-extrabold text-[var(--color-primary)]">{entry.data.customers}</p>
          <p class="mt-1 text-sm text-[var(--color-text-muted)]">در حال استفاده از این راهکار</p>
          <div class="mt-5 border-t border-[var(--color-border)] pt-5">
            <p class="text-sm font-bold">شامل این راهکار:</p>
            <ul class="mt-3 space-y-2 text-sm text-[var(--color-text-muted)]">
              {entry.data.features.slice(0, 4).map((f: string) => <li>• {f}</li>)}
            </ul>
          </div>
          <Button href={`/contact/?subject=${encodeURIComponent(entry.data.title)}`} variant="primary" class="mt-6 w-full">
            درخواست مشاوره رایگان
          </Button>
        </div>
      </aside>
    </div>

    {
      relatedHardwareEntries.filter(Boolean).length > 0 && (
        <div class="mt-16">
          <h2 class="mb-4 text-lg font-bold">سخت‌افزار مرتبط</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {relatedHardwareEntries.filter(Boolean).map((h) => (
              <Card href={`/hardware/${h!.id}/`} title={h!.data.title} summary={h!.data.summary} icon={h!.data.icon} stat={h!.data.customers} />
            ))}
          </div>
        </div>
      )
    }
  </div>

  <CTASection subject={entry.data.title} />
</BaseLayout>

<style>
  .prose-content :global(h2) {
    margin-top: 2rem;
    font-size: 1.5rem;
    font-weight: 700;
  }
  .prose-content :global(h3) {
    margin-top: 1.5rem;
    font-size: 1.25rem;
    font-weight: 700;
  }
  .prose-content :global(p) {
    margin-top: 1rem;
  }
  .prose-content :global(ul) {
    margin-top: 1rem;
    list-style: disc;
    padding-inline-start: 1.5rem;
  }
  .prose-content :global(li) {
    margin-top: 0.4rem;
  }
  .prose-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
