---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import CTASection from '../../components/ui/CTASection.astro';
import { withBase } from '../../lib/url';

const whyPoints = [
  'راهکارهای قابل سفارشی‌سازی بر اساس نیاز واقعی کسب‌وکار',
  'پشتیبانی فنی مستقیم، نه صف تیکت طولانی',
  'ترکیب نرم‌افزار و سخت‌افزار در یک راهکار یکپارچه',
  'سابقه‌ی همکاری با کسب‌وکارهایی در صنوف مختلف',
];
---

<BaseLayout
  title="درباره ما"
  description="نوپردازان زندگی هوشمند؛ شرکت مهندسی نرم‌افزار متخصص در باشگاه مشتریان، فروشگاه‌ساز اینترنتی، یکپارچه‌سازی حسابداری و مدیریت تگ NFC."
  breadcrumb={[
    { name: 'خانه', url: '/' },
    { name: 'درباره ما', url: '/about/' },
  ]}
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[{ name: 'خانه', href: '/' }, { name: 'درباره ما', href: '/about/' }]} />
    <h1 class="text-3xl font-extrabold">درباره نوپردازان</h1>

    <p class="mt-6 text-lg leading-8 text-[var(--color-text-muted)]">
      نوپردازان زندگی هوشمند یک شرکت مهندسی نرم‌افزار است که راهکارهای نرم‌افزاری و سخت‌افزاری کاربردی برای
      کسب‌وکارهای کوچک و متوسط طراحی و پیاده‌سازی می‌کند؛ از باشگاه مشتریان و فروشگاه‌ساز اینترنتی گرفته تا
      یکپارچه‌سازی سیستم‌های مالی و مدیریت تگ NFC.
    </p>

    <div class="mt-8 grid grid-cols-3 gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-card)]">
      <div class="text-center">
        <p class="text-xl font-extrabold text-[var(--color-primary)]">۷</p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">راهکار و محصول</p>
      </div>
      <div class="border-x border-[var(--color-border)] text-center">
        <p class="text-xl font-extrabold text-[var(--color-primary)]">۵۰+</p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">مشتری هر راهکار</p>
      </div>
      <div class="text-center">
        <p class="text-xl font-extrabold text-[var(--color-primary)]">۱۰۰+</p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">مربی با شهروز فیتنس</p>
      </div>
    </div>

    <h2 class="mt-10 text-xl font-bold">رویکرد ما</h2>
    <p class="mt-3 leading-8 text-[var(--color-text-muted)]">
      به‌جای فروش یک محصول خام، تلاش می‌کنیم مسئله‌ی واقعی کسب‌وکار شما را بفهمیم و راهکاری متناسب با همان مسئله
      ارائه کنیم — چه یک محصول آماده باشد و چه نیازمند توسعه‌ی اختصاصی، مثل
      <a href={withBase('/portfolio/shahrooz-fitness/')} class="font-medium text-[var(--color-primary)]"> نمونه‌کار شهروز فیتنس</a>.
    </p>

    <h2 class="mt-10 text-xl font-bold">چرا نوپردازان</h2>
    <ul class="mt-4 grid gap-3 sm:grid-cols-2">
      {whyPoints.map((point) => (
        <li class="flex items-start gap-2.5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm text-[var(--color-text-muted)]">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-[var(--color-accent)]/15 text-[var(--color-accent)]">
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          {point}
        </li>
      ))}
    </ul>
    <p class="mt-3">
      <a href={withBase('/testimonials/')} class="text-sm font-medium text-[var(--color-primary)]">نظر مشتریان ما را بخوانید ←</a>
    </p>

    <p class="mt-10 rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-sm text-[var(--color-text-muted)]">
      این بخش پس از دریافت متن نهایی درباره‌ی تاریخچه، ماموریت و تیم از کارفرما تکمیل می‌شود.
    </p>
  </div>

  <CTASection />
</BaseLayout>
