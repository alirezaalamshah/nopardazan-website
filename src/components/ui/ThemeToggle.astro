---
---

<button
  type="button"
  class="theme-toggle-btn inline-flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text)] transition-colors hover:bg-[var(--color-surface)]"
  aria-label="تغییر حالت نمایش روشن/تاریک"
>
  <svg
    class="theme-icon-dark h-5 w-5"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4.2"></circle>
    <path
      stroke-linecap="round"
      d="M12 2.5v2M12 19.5v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2.5 12h2M19.5 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"
    ></path>
  </svg>
  <svg
    class="theme-icon-light h-5 w-5"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"
    ></path>
  </svg>
</button>

<script is:inline>
  /*
    Each <ThemeToggle /> usage (desktop + mobile copies) renders its own
    button + script pair. Using an id + getElementById here would always
    resolve to the FIRST button in the document from BOTH script instances,
    attaching two listeners to the same element (so a click toggled it twice
    and visibly did nothing). Anchoring off `currentScript.previousElementSibling`
    guarantees each script only ever wires up its own adjacent button.
  */
  (() => {
    const btn = document.currentScript?.previousElementSibling;
    btn?.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  })();
</script>
