---
interface Props {
  name:
    | 'heart'
    | 'shopping-bag'
    | 'link'
    | 'nfc'
    | 'card-reader'
    | 'dumbbell'
    | 'cube'
    | 'phone'
    | 'mail'
    | 'whatsapp';
  class?: string;
}

const { name, class: className = 'h-6 w-6' } = Astro.props;

const paths: Record<string, string> = {
  heart: 'M12 20.5s-7.5-4.6-10-9.3C.4 8 1.7 4.5 5 3.6c2-.5 4 .3 5 2 1-1.7 3-2.5 5-2 3.3.9 4.6 4.4 3 7.6-2.5 4.7-10 9.3-10 9.3Z',
  'shopping-bag':
    'M5 8h14l-1 12.5a1.5 1.5 0 0 1-1.5 1.5H7.5A1.5 1.5 0 0 1 6 20.5L5 8Zm3 0V6a4 4 0 1 1 8 0v2',
  link: 'M9.5 14.5 14.5 9.5M8 16 5.5 18.5a3.2 3.2 0 0 1-4.5-4.5L3.5 11.5M16 8l2.5-2.5a3.2 3.2 0 0 1 4.5 4.5L20.5 12.5',
  cube: 'M12 2 21 7v10l-9 5-9-5V7l9-5Zm0 0v20M3 7l9 5 9-5',
  phone:
    'M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1L6.6 10.8Z',
  mail: 'M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm0 0 8 7 8-7',
};
---

{
  name === 'nfc' ? (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <rect x="3" y="6" width="12" height="14" rx="2"></rect>
      <circle cx="9" cy="13" r="2"></circle>
      <path stroke-linecap="round" d="M18 7a6 6 0 0 1 0 8M21 4.5a10 10 0 0 1 0 13"></path>
    </svg>
  ) : name === 'card-reader' ? (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <rect x="3" y="4" width="18" height="12" rx="2"></rect>
      <path stroke-linecap="round" d="M3 9h18M7 13h3"></path>
      <path stroke-linecap="round" d="M9 20h6"></path>
    </svg>
  ) : name === 'dumbbell' ? (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 9v6M2 10.5v3M7 7v10M17 7v10M20 9v6M22 10.5v3" />
      <path stroke-linecap="round" d="M7 12h10" />
    </svg>
  ) : name === 'whatsapp' ? (
    <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8.9-.1.2-.3.2-.5.1-.2-.1-1-.4-1.9-1.2-.7-.6-1.2-1.4-1.3-1.6-.1-.2 0-.4.1-.5l.4-.4c.1-.1.2-.3.2-.4.1-.1.1-.3 0-.4-.1-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.4.1-.6.3-.2.2-.8.8-.8 1.9 0 1.1.8 2.2.9 2.3.1.2 1.6 2.5 3.9 3.4.5.2 1 .4 1.3.5.5.2 1 .1 1.3-.1.4-.2 1.2-1 1.4-1.4.2-.4.2-.7.1-.8-.1-.1-.2-.2-.4-.3Z" />
    </svg>
  ) : (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d={paths[name] ?? paths.cube}></path>
    </svg>
  )
}
