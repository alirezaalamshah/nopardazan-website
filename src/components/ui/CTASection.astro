---
import Button from './Button.astro';
import { siteConfig } from '../../lib/nav';

interface Props {
  title?: string;
  subject?: string;
}

const { title = 'برای مشاوره رایگان و دریافت قیمت با ما در تماس باشید', subject } = Astro.props;
const contactHref = subject ? `/contact/?subject=${encodeURIComponent(subject)}` : '/contact/';
---

<section
  class="relative mx-auto my-16 max-w-5xl overflow-hidden rounded-3xl border border-[var(--color-border)] px-6 py-12 text-center sm:px-12"
  style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 10%, var(--color-surface)), var(--color-surface));"
>
  <div
    class="pointer-events-none absolute -top-24 start-1/2 h-56 w-56 -translate-x-1/2 rounded-full opacity-20 blur-3xl"
    style="background: var(--color-primary);"
  >
  </div>
  <h2 class="text-xl font-bold sm:text-2xl">{title}</h2>
  <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
    <Button href={`tel:${siteConfig.phone.replace(/-/g, '')}`} variant="secondary">
      تماس تلفنی: {siteConfig.phone}
    </Button>
    <Button href={siteConfig.whatsapp} variant="secondary">پیام واتس‌اپ</Button>
    <Button href={contactHref} variant="primary">رفتن به فرم تماس</Button>
  </div>
</section>
