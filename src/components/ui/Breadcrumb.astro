---
import { withBase } from '../../lib/url';

interface Crumb {
  name: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="مسیر دسترسی" class="mb-6 text-sm text-[var(--color-text-muted)]">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true">/</span>}
          {i === items.length - 1 ? (
            <span class="text-[var(--color-text)]">{item.name}</span>
          ) : (
            <a href={withBase(item.href)} class="hover:text-[var(--color-primary)]">
              {item.name}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
